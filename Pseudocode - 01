<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <style>
        button {
            background-color: blue;
            color: antiquewhite;
            padding: 20px;
            margin: 10px;
            border: double;
            cursor: pointer;
            transition: 0.6s;
        }

        button:hover {
            background-color: black;
        }

        button:active {
            transform: scale(0.9);
        }

        input {
            padding: 8px;
        }

        input:focus {
            border: 2px dotted blue;
        }
    </style>
</head>
<body>

    <button>
        click mee
    </button><br><br>

    <input type="text" placeholder="type here">

</body>
</html>
